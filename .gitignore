# ADHIKAR - .gitignore

# ----------------------------------------------------------------------------
# System Files
# ----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
desktop.ini
ehthumbs.db
Thumbs.db
*.log
*.class

# ----------------------------------------------------------------------------
# Flutter / Dart
# ----------------------------------------------------------------------------
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/

# ----------------------------------------------------------------------------
# IDE - VS Code
# ----------------------------------------------------------------------------
.vscode/
!.vscode/launch.json
!.vscode/settings.json
!.vscode/tasks.json

# ----------------------------------------------------------------------------
# IDE - IntelliJ / Android Studio
# ----------------------------------------------------------------------------
*.iml
*.ipr
*.iws
.idea/
/android/app/debug
/android/app/profile
/android/app/release

# ----------------------------------------------------------------------------
# Android Related
# ----------------------------------------------------------------------------
android/.gradle/
android/local.properties
android/captures/
android/key.properties
**/android/**/generated/
*.keystore
*.jks

# ----------------------------------------------------------------------------
# iOS Related
# ----------------------------------------------------------------------------
ios/Pods/
ios/.symlinks/
ios/Flutter/flutter_export_environment.sh
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_plugins_dependencies.product.bundle
ios/ServiceDefinitions.json
ios/Runner/Generated.xcconfig
*.cert
*.mobileprovision
*.p12
*.pem

# ----------------------------------------------------------------------------
# Windows Related
# ----------------------------------------------------------------------------
windows/flutter/ephemeral/
windows/flutter/generated_config.cmake

# ----------------------------------------------------------------------------
# Environment Variables & Secrets (CRITICAL)
# ----------------------------------------------------------------------------
.env
.env.*
*.env
!.env.example

# ----------------------------------------------------------------------------
# Firebase
# ----------------------------------------------------------------------------
# Note: google-services.json is excluded to prevent leaking credentials.
# Users should add their own.
google-services.json
GoogleService-Info.plist
firebase-debug.log*
.firebase/

# ----------------------------------------------------------------------------
# Generated Code (Build Runner)
# ----------------------------------------------------------------------------
# Standard practice for apps is to ignore generated files if they can be rebuilt.
*.g.dart
*.freezed.dart

# ----------------------------------------------------------------------------
# Miscellaneous
# ----------------------------------------------------------------------------
app.*.symbols
app.*.map.json
/files/
/tmp/